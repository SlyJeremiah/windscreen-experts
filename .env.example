# Copy to .env and fill in real values

# Django
SECRET_KEY=your-secret-key-here
DEBUG=False

# PostgreSQL (Vercel Postgres or Supabase)
DATABASE_URL=postgres://user:password@host:5432/dbname

# Email – Gmail SMTP
EMAIL_HOST_USER=munashe@windowscreens.co.zw
EMAIL_HOST_PASSWORD=your-gmail-app-password
ADMIN_EMAIL=munashe@windowscreens.co.zw

# Backblaze B2 Storage
USE_BACKBLAZE=True
B2_KEY_ID=your-key-id
B2_APPLICATION_KEY=your-application-key
B2_BUCKET_NAME=windscreen-experts-media
B2_ENDPOINT_URL=https://s3.us-west-002.backblazeb2.com

# Google Analytics
GA_MEASUREMENT_ID=G-XXXXXXXXXX
